
# E3 Configuration
E3_API_TITLE=E3: Integration &amp; Action API
E3_API_VERSION=v1

# Database
E3_DATABASE_URL=postgresql+asyncpg://e3_user:e3_pass@localhost:5432/e3_db
E3_DATABASE_POOL_SIZE=20

# Redis
E3_REDIS_URL=redis://localhost:6379/0

# Celery
E3_CELERY_BROKER_URL=redis://localhost:6379/1
E3_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OAuth (Google)
E3_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
E3_GOOGLE_CLIENT_SECRET=your-client-secret
E3_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Webhook
E3_WEBHOOK_SECRET=change-this-in-production

# Monitoring
E3_ENABLE_PROMETHEUS=true

