# Application
APP_NAME=myproj
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://myproj:myproj@localhost:5432/myproj
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# API Configuration
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SSE_URL=/api/sse

# Feature Flags
NEXT_PUBLIC_USE_MOCK=true

# Environment
NODE_ENV=development
# E5 - AI/Agent Intelligence Layer 环境配置示例
# 复制此文件为 .env 并填入实际值

# ============= 基础配置 =============
NODE_ENV=development
E5_PORT=8085
E5_HOST=0.0.0.0

# ============= LLM配置 =============
# OpenAI配置 (二选一或同时配置)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic配置 (可选)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 模型配置
E5_DEFAULT_MODEL=gpt-4o
E5_FALLBACK_MODEL=gpt-4o-mini

# ============= 缓存配置 =============
E5_CACHE_ENABLED=true
E5_REDIS_URL=redis://localhost:6379

# ============= 日志配置 =============
E5_LOG_LEVEL=info
E5_ENABLE_LLM_TRACE=false

# ============= 评估配置 =============
E5_ENABLE_HUMAN_EVAL=false
E5_AUTO_SAVE_EVALS=true
